ANTHROPIC_API_KEY=
# Default model when the more specific vars below are unset (falls back to Haiku in code for speed).
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
# Optional: faster model for specialist agents (transport, stay, activity, optimizer).
# ANTHROPIC_MODEL_AGENTS=claude-3-5-haiku-20241022
# Optional: judge only (defaults to same resolution order as agents).
# ANTHROPIC_MODEL_JUDGE=claude-3-5-haiku-20241022

TAVILY_API_KEY=

PLANORA_DB_PATH=data/planora.db
PLANORA_JUDGE_THRESHOLD=7
# Lower = fewer judge retry loops (faster). 0 disables refinement.
PLANORA_MAX_REFINEMENT_LOOPS=1
# Skip Tavily entirely (faster; agents rely on other tools + model knowledge).
# PLANORA_SKIP_WEB_SEARCH=true
# Seconds to reuse identical web_search_travel queries (0 = no cache).
# PLANORA_WEB_SEARCH_CACHE_TTL=3600
